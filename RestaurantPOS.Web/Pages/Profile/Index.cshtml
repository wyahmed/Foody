@page "/Profile"
@model RestaurantPOS.Web.Pages.Profile.IndexModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">
            <i class="bi bi-person-circle text-success me-2"></i>My Profile
        </h4>
        <small class="text-muted">Manage your account information</small>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <!-- Profile Card -->
    <div class="col-lg-4">
        <div class="card pos-card text-center p-4">
            <div class="d-flex justify-content-center mb-3">
                <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center fw-bold"
                     style="width:80px;height:80px;font-size:2rem">
                    @Model.FullName.Substring(0, 1).ToUpperInvariant()
                </div>
            </div>
            <h5 class="fw-bold mb-1">@Model.FullName</h5>
            <p class="text-muted small mb-2">@Model.Email</p>
            @if (!string.IsNullOrEmpty(Model.EmployeeCode))
            {
                <span class="badge bg-secondary">@Model.EmployeeCode</span>
            }
            <hr />
            <div class="text-start small">
                <div class="d-flex gap-2 mb-2">
                    <i class="bi bi-building text-muted"></i>
                    <span>@(Model.BranchName ?? "All Branches")</span>
                </div>
                <div class="d-flex gap-2 mb-2">
                    <i class="bi bi-shield-check text-muted"></i>
                    <span>@string.Join(", ", Model.Roles)</span>
                </div>
                <div class="d-flex gap-2">
                    <i class="bi bi-clock text-muted"></i>
                    <span>Last login: @(Model.LastLogin?.ToString("dd MMM yyyy HH:mm") ?? "—")</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Profile -->
    <div class="col-lg-8">
        <div class="card pos-card mb-3">
            <div class="card-header fw-semibold">
                <i class="bi bi-person me-2"></i>Personal Information
            </div>
            <div class="card-body">
                <form method="post" asp-page-handler="UpdateProfile">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">First Name</label>
                            <input type="text" name="FirstName" value="@Model.FirstName"
                                   class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Last Name</label>
                            <input type="text" name="LastName" value="@Model.LastName"
                                   class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">First Name (Arabic)</label>
                            <input type="text" name="FirstNameAr" value="@Model.FirstNameAr"
                                   class="form-control" dir="rtl" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Last Name (Arabic)</label>
                            <input type="text" name="LastNameAr" value="@Model.LastNameAr"
                                   class="form-control" dir="rtl" />
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-lg me-1"></i>Save Changes
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Change Password -->
        <div class="card pos-card">
            <div class="card-header fw-semibold">
                <i class="bi bi-lock me-2"></i>Change Password
            </div>
            <div class="card-body">
                <form method="post" asp-page-handler="ChangePassword">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Current Password</label>
                            <input type="password" name="CurrentPassword" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">New Password</label>
                            <input type="password" name="NewPassword" class="form-control"
                                   minlength="6" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Confirm New Password</label>
                            <input type="password" name="ConfirmPassword" class="form-control"
                                   minlength="6" required />
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-outline-danger">
                                <i class="bi bi-key me-1"></i>Change Password
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
