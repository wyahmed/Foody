<!DOCTYPE html>
<html lang="@(ViewData["Lang"]?.ToString() ?? "ar")"
      dir="@(ViewData["Lang"]?.ToString() == "en" ? "ltr" : "rtl")"
      data-bs-theme="@(ViewData["Theme"]?.ToString() ?? "light")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="RestaurantPOS - Complete Point of Sale Solution" />
    <title>@ViewData["Title"] – RestaurantPOS</title>
    <link rel="icon" href="~/favicon.ico" type="image/x-icon" />

    <!-- Bootstrap 5 -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          crossorigin="anonymous" />
    @if (ViewData["Lang"]?.ToString() != "en")
    {
        <link rel="stylesheet"
              href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css"
              crossorigin="anonymous" />
    }
    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- Custom POS styles -->
    <link rel="stylesheet" href="~/css/pos.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <!-- Top Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark pos-navbar fixed-top shadow-sm">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/Dashboard">
                <i class="bi bi-shop-window me-2"></i>RestaurantPOS
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                <!-- Search -->
                <form class="d-flex ms-3 me-auto" action="/Products" method="get">
                    <div class="input-group">
                        <input class="form-control form-control-sm" type="search" name="q"
                               placeholder="@(ViewData["Lang"]?.ToString() == "en" ? "Search products, orders..." : "بحث عن منتجات، طلبات...")"
                               style="min-width:280px" />
                        <button class="btn btn-outline-light btn-sm"><i class="bi bi-search"></i></button>
                    </div>
                </form>

                <ul class="navbar-nav align-items-center gap-2">
                    <!-- Notifications -->
                    <li class="nav-item dropdown">
                        <a class="nav-link position-relative" href="#" role="button"
                           data-bs-toggle="dropdown">
                            <i class="bi bi-bell-fill fs-5"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                  id="notif-count" style="display:none">0</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" style="min-width:320px">
                            <li><h6 class="dropdown-header">Notifications</h6></li>
                            <li id="notif-list"><li class="dropdown-item text-muted small">No new notifications</li></li>
                        </ul>
                    </li>

                    <!-- Dark Mode Toggle -->
                    <li class="nav-item">
                        <button class="btn btn-link nav-link" onclick="toggleTheme()" title="Toggle theme">
                            <i class="bi bi-moon-stars-fill" id="theme-icon"></i>
                        </button>
                    </li>

                    <!-- Language Switch -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-translate me-1"></i>
                            @(ViewData["Lang"]?.ToString() == "en" ? "EN" : "ع")
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="#" onclick="setLang('ar')">العربية</a></li>
                            <li><a class="dropdown-item" href="#" onclick="setLang('en')">English</a></li>
                        </ul>
                    </li>

                    <!-- User menu -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#"
                           data-bs-toggle="dropdown">
                            <div class="rounded-circle bg-white text-success d-flex align-items-center justify-content-center fw-bold"
                                 style="width:32px;height:32px;font-size:14px">
                                @(User.Identity?.Name?.Substring(0, 1).ToUpperInvariant() ?? "A")
                            </div>
                            <span class="d-none d-md-inline">@User.Identity?.Name</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/Profile"><i class="bi bi-person me-2"></i>Profile</a></li>
                            <li><a class="dropdown-item" href="/Settings"><i class="bi bi-gear me-2"></i>Settings</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form method="post" action="/Account/Logout">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i>Sign Out
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Sidebar + Main Content -->
    <div class="d-flex" style="margin-top: 56px;">
        <!-- Sidebar -->
        <nav class="pos-sidebar d-none d-lg-block" id="sidebar">
            <div class="p-3">
                <ul class="nav flex-column gap-1">
                    @{
                        var nav = new (string Href, string Icon, string Label)[]
                        {
                            ("/Dashboard", "bi-speedometer2", "Dashboard"),
                            ("/POS", "bi-bag-plus-fill", "POS"),
                            ("/Orders", "bi-receipt-cutoff", "Orders"),
                            ("/Kitchen", "bi-fire", "Kitchen"),
                            ("/Tables", "bi-layout-three-columns", "Tables"),
                            ("/Categories", "bi-tags", "Categories"),
                            ("/Products", "bi-box-seam", "Products"),
                            ("/Inventory", "bi-boxes", "Inventory"),
                            ("/Customers", "bi-people-fill", "Customers"),
                            ("/Reports", "bi-bar-chart-fill", "Reports"),
                            ("/Branches", "bi-building", "Branches"),
                            ("/Employees", "bi-person-badge", "Employees"),
                            ("/Settings", "bi-gear-fill", "Settings"),
                        };
                        var currentPath = Context.Request.Path.Value ?? "";
                    }
                    @foreach (var item in nav)
                    {
                        var isActive = currentPath.StartsWith(item.Href, StringComparison.OrdinalIgnoreCase);
                        <li class="nav-item">
                            <a href="@item.Href"
                               class="nav-link d-flex align-items-center gap-2 rounded px-3 py-2 @(isActive ? "active" : "text-secondary")">
                                <i class="bi @item.Icon"></i>
                                <span>@item.Label</span>
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="flex-grow-1 p-4" style="min-width: 0;">
            @RenderBody()
        </main>
    </div>

    <!-- Toast container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" id="toast-container"></div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/htmx.org@1.9.12"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@7.0.5/dist/browser/signalr.min.js"></script>
    <script src="~/js/pos.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
