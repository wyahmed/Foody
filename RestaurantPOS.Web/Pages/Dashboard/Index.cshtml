@page "/Dashboard"
@model RestaurantPOS.Web.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = Localizer["Dashboard"];
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">
            <i class="bi bi-speedometer2 text-success me-2"></i>@Localizer["Dashboard"]
        </h4>
        <small class="text-muted">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</small>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary btn-sm" onclick="location.reload()">
            <i class="bi bi-arrow-clockwise me-1"></i>@Localizer["Refresh"]
        </button>
        <a href="/POS" class="btn btn-success btn-sm">
            <i class="bi bi-bag-plus-fill me-1"></i>@Localizer["New Sale"]
        </a>
    </div>
</div>

<!-- Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="stat-icon bg-success bg-opacity-10 text-success">
                    <i class="bi bi-currency-dollar"></i>
                </div>
                <div>
                    <div class="text-muted small">@Localizer["Today's Sales"]</div>
                    <div class="fw-bold fs-5">@Model.TodaySales.ToString("N2") @Localizer["SAR"]</div>
                    <small class="text-success"><i class="bi bi-arrow-up-short"></i>@Model.SalesGrowth%</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                    <i class="bi bi-receipt"></i>
                </div>
                <div>
                    <div class="text-muted small">@Localizer["Today's Orders"]</div>
                    <div class="fw-bold fs-5">@Model.TodayOrders</div>
                    <small class="text-muted">@Localizer["{0} pending", Model.PendingOrders]</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-people"></i>
                </div>
                <div>
                    <div class="text-muted small">@Localizer["Customers"]</div>
                    <div class="fw-bold fs-5">@Model.TodayCustomers</div>
                    <small class="text-muted">@Localizer["today"]</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="stat-icon bg-danger bg-opacity-10 text-danger">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <div>
                    <div class="text-muted small">@Localizer["Low Stock Items"]</div>
                    <div class="fw-bold fs-5">@Model.LowStockCount</div>
                    <a href="/Inventory?filter=lowstock" class="text-danger small">@Localizer["View all"]</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts & Tables Row -->
<div class="row g-3 mb-4">
    <!-- Recent Orders -->
    <div class="col-lg-7">
        <div class="card pos-card h-100">
            <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                <h6 class="fw-bold mb-0"><i class="bi bi-clock-history me-2 text-primary"></i>@Localizer["Recent Orders"]</h6>
                <a href="/Orders" class="btn btn-link btn-sm p-0">@Localizer["View all"]</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">@Localizer["Order #"]</th>
                                <th>@Localizer["Customer"]</th>
                                <th>@Localizer["Type"]</th>
                                <th>@Localizer["Total"]</th>
                                <th>@Localizer["Status"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.RecentOrders)
                            {
                                <tr>
                                    <td class="ps-3">
                                        <a href="/Orders/@order.Id" class="fw-semibold text-decoration-none">@order.OrderNumber</a>
                                    </td>
                                    <td>@(order.CustomerName ?? Localizer["Walk-in"])</td>
                                    <td><span class="badge bg-secondary">@order.OrderType</span></td>
                                    <td class="fw-semibold">@order.TotalAmount.ToString("N2")</td>
                                    <td>
                                        <span class="badge @GetStatusBadge(order.Status.ToString())">@order.Status</span>
                                    </td>
                                </tr>
                            }
                            @if (!Model.RecentOrders.Any())
                            {
                                <tr><td colspan="5" class="text-center text-muted py-4">@Localizer["No orders today"]</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Top Products -->
    <div class="col-lg-5">
        <div class="card pos-card h-100">
            <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                <h6 class="fw-bold mb-0"><i class="bi bi-trophy me-2 text-warning"></i>@Localizer["Top Products Today"]</h6>
            </div>
            <div class="card-body">
                @foreach (var (product, index) in Model.TopProducts.Select((p, i) => (p, i)))
                {
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="rounded-circle bg-success bg-opacity-10 text-success d-flex align-items-center justify-content-center fw-bold"
                             style="width:36px;height:36px;font-size:13px;flex-shrink:0">
                            @(index + 1)
                        </div>
                        <div class="flex-grow-1">
                            <div class="fw-semibold" style="font-size:.9rem">@product.Name</div>
                            <div class="progress mt-1" style="height:4px">
                                <div class="progress-bar bg-success" style="width:@product.Percentage%"></div>
                            </div>
                        </div>
                        <div class="text-end">
                            <div class="fw-bold text-success small">@product.Revenue.ToString("N0")</div>
                            <div class="text-muted" style="font-size:.75rem">x@product.Quantity</div>
                        </div>
                    </div>
                }
                @if (!Model.TopProducts.Any())
                {
                    <p class="text-center text-muted py-3">@Localizer["No sales data yet"]</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- Kitchen / Tables Status -->
<div class="row g-3">
    <div class="col-lg-6">
        <div class="card pos-card">
            <div class="card-header bg-transparent d-flex justify-content-between">
                <h6 class="fw-bold mb-0"><i class="bi bi-fire me-2 text-danger"></i>@Localizer["Kitchen Queue"]</h6>
                <a href="/Kitchen" class="btn btn-link btn-sm p-0">@Localizer["Open KDS"]</a>
            </div>
            <div class="card-body">
                @if (Model.KitchenOrders.Any())
                {
                    <div class="row g-2">
                        @foreach (var ko in Model.KitchenOrders.Take(6))
                        {
                            <div class="col-6">
                                <div class="border rounded p-2 small">
                                    <div class="fw-bold">@ko.OrderNumber</div>
                                    <div class="text-muted">@ko.Status</div>
                                    <div class="text-muted" style="font-size:.75rem">@ko.CreatedAgo</div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-center text-muted py-3"><i class="bi bi-check-circle text-success me-2"></i>@Localizer["Kitchen queue is empty"]</p>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card pos-card">
            <div class="card-header bg-transparent d-flex justify-content-between">
                <h6 class="fw-bold mb-0"><i class="bi bi-layout-three-columns me-2 text-info"></i>@Localizer["Table Status"]</h6>
                <a href="/Tables" class="btn btn-link btn-sm p-0">@Localizer["Manage Tables"]</a>
            </div>
            <div class="card-body">
                <div class="d-flex gap-3 mb-3">
                    <div class="text-center">
                        <div class="fw-bold fs-4 text-success">@Model.AvailableTables</div>
                        <div class="text-muted small">@Localizer["Available"]</div>
                    </div>
                    <div class="text-center">
                        <div class="fw-bold fs-4 text-danger">@Model.OccupiedTables</div>
                        <div class="text-muted small">@Localizer["Occupied"]</div>
                    </div>
                    <div class="text-center">
                        <div class="fw-bold fs-4 text-warning">@Model.ReservedTables</div>
                        <div class="text-muted small">@Localizer["Reserved"]</div>
                    </div>
                </div>
                <div class="progress" style="height:8px">
                    @{ var totalTables = Model.AvailableTables + Model.OccupiedTables + Model.ReservedTables; }
                    @if (totalTables > 0)
                    {
                        <div class="progress-bar bg-danger" style="width:@(Model.OccupiedTables * 100 / totalTables)%"></div>
                        <div class="progress-bar bg-warning" style="width:@(Model.ReservedTables * 100 / totalTables)%"></div>
                        <div class="progress-bar bg-success" style="width:@(Model.AvailableTables * 100 / totalTables)%"></div>
                    }
                </div>
                <div class="d-flex justify-content-between mt-1">
                    <small class="text-muted">@Localizer["Occupied {0}%", totalTables > 0 ? (Model.OccupiedTables * 100 / totalTables) : 0]</small>
                    <small class="text-muted">@Localizer["{0} total tables", totalTables]</small>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    static string GetStatusBadge(string status) => status switch
    {
        "Completed" => "bg-success",
        "Pending" => "bg-warning text-dark",
        "Cancelled" => "bg-danger",
        "Preparing" => "bg-info",
        _ => "bg-secondary"
    };
}

@section Scripts {
    <script>
        // Connect to SignalR for real-time dashboard updates
        const branchId = '@Model.BranchId';
        if (branchId) connectSignalR(branchId);

        // Auto-refresh dashboard every 60 seconds
        setTimeout(() => location.reload(), 60000);
    </script>
}
