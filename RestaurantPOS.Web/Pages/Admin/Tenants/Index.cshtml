@page "/Admin/Tenants"
@model RestaurantPOS.Web.Pages.Admin.Tenants.IndexModel
@{
    ViewData["Title"] = Localizer["Tenant Management"];
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">
            <i class="bi bi-buildings text-success me-2"></i>@Localizer["Tenants"]
        </h4>
        <small class="text-muted">@Localizer["Manage all tenants in the system"]</small>
    </div>
    <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#addTenantModal">
        <i class="bi bi-plus-circle me-1"></i>@Localizer["Add Tenant"]
    </button>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card pos-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>@Localizer["Name"]</th>
                        <th>@Localizer["Contact"]</th>
                        <th>@Localizer["VAT / CR"]</th>
                        <th>@Localizer["Currency"]</th>
                        <th>@Localizer["ZATCA Env"]</th>
                        <th>@Localizer["Created"]</th>
                        <th>@Localizer["Status"]</th>
                        <th class="text-end">@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tenant in Model.Tenants)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@tenant.Name</div>
                                <div class="text-muted small">@tenant.NameAr</div>
                            </td>
                            <td>
                                <div class="small">@(tenant.Email ?? "—")</div>
                                <div class="small text-muted">@(tenant.Phone ?? "—")</div>
                            </td>
                            <td>
                                <div class="small">@(tenant.VatNumber ?? "—")</div>
                                <div class="small text-muted">@(tenant.CommercialRegistration ?? "—")</div>
                            </td>
                            <td class="small">@(tenant.Currency ?? Localizer["SAR"])</td>
                            <td>
                                <span class="badge @(tenant.ZatcaEnvironment == "Production" ? "bg-danger" : "bg-warning text-dark")">
                                    @(tenant.ZatcaEnvironment ?? Localizer["Sandbox"])
                                </span>
                            </td>
                            <td class="small text-muted">@tenant.CreatedDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                <span class="badge @(tenant.IsActive ? "bg-success" : "bg-secondary")">
                                    @(tenant.IsActive ? Localizer["Active"] : Localizer["Inactive"])
                                </span>
                            </td>
                            <td class="text-end">
                                <button class="btn btn-outline-secondary btn-sm"
                                        onclick="editTenant('@tenant.Id', '@tenant.Name.Replace("'", "\\'")', '@(tenant.NameAr?.Replace("'", "\\'"))', '@(tenant.VatNumber ?? "")', '@(tenant.CommercialRegistration ?? "")', '@(tenant.Phone ?? "")', '@(tenant.Email ?? "")', '@(tenant.Address ?? "")', '@(tenant.City ?? "")', '@(tenant.Country ?? "SA")', '@(tenant.Currency ?? "SAR")', '@(tenant.DefaultLanguage ?? "ar")')">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <form method="post" asp-page-handler="ToggleActive" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@tenant.Id" />
                                    <button type="submit" class="btn btn-sm @(tenant.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                            title="@(tenant.IsActive ? Localizer["Deactivate"] : Localizer["Activate"])">
                                        <i class="bi @(tenant.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Tenants.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-5">
                                <i class="bi bi-buildings fs-1 d-block mb-2"></i>
                                @Localizer["No tenants found."]
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add Tenant Modal -->
<div class="modal fade" id="addTenantModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" asp-page-handler="Create">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-buildings me-2"></i>@Localizer["Add Tenant"]</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Name (EN)"] <span class="text-danger">*</span></label>
                            <input type="text" name="name" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Name (AR)"]</label>
                            <input type="text" name="nameAr" class="form-control" dir="rtl" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["VAT Number"]</label>
                            <input type="text" name="vatNumber" class="form-control" maxlength="15" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Commercial Registration"]</label>
                            <input type="text" name="commercialRegistration" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Email"]</label>
                            <input type="email" name="email" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Phone"]</label>
                            <input type="text" name="phone" class="form-control" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">@Localizer["Address"]</label>
                            <input type="text" name="address" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">@Localizer["City"]</label>
                            <input type="text" name="city" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">@Localizer["Country"]</label>
                            <input type="text" name="country" class="form-control" value="SA" maxlength="2" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">@Localizer["Currency"]</label>
                            <select name="currency" class="form-select">
                                <option value="SAR" selected>@Localizer["SAR – Saudi Riyal"]</option>
                                <option value="AED">@Localizer["AED – UAE Dirham"]</option>
                                <option value="KWD">@Localizer["KWD – Kuwaiti Dinar"]</option>
                                <option value="BHD">@Localizer["BHD – Bahraini Dinar"]</option>
                                <option value="QAR">@Localizer["QAR – Qatari Riyal"]</option>
                                <option value="OMR">@Localizer["OMR – Omani Rial"]</option>
                                <option value="USD">@Localizer["USD – US Dollar"]</option>
                                <option value="EUR">@Localizer["EUR – Euro"]</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">@Localizer["Default Language"]</label>
                            <select name="defaultLanguage" class="form-select">
                                <option value="ar" selected>@Localizer["Arabic"]</option>
                                <option value="en">@Localizer["English"]</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Cancel"]</button>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg me-1"></i>@Localizer["Create Tenant"]
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Tenant Modal -->
<div class="modal fade" id="editTenantModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" asp-page-handler="Update">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="editId" />
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>@Localizer["Edit Tenant"]</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Name (EN)"] <span class="text-danger">*</span></label>
                            <input type="text" name="name" id="editName" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Name (AR)"]</label>
                            <input type="text" name="nameAr" id="editNameAr" class="form-control" dir="rtl" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["VAT Number"]</label>
                            <input type="text" name="vatNumber" id="editVatNumber" class="form-control" maxlength="15" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Commercial Registration"]</label>
                            <input type="text" name="commercialRegistration" id="editCR" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Email"]</label>
                            <input type="email" name="email" id="editEmail" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Phone"]</label>
                            <input type="text" name="phone" id="editPhone" class="form-control" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">@Localizer["Address"]</label>
                            <input type="text" name="address" id="editAddress" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">@Localizer["City"]</label>
                            <input type="text" name="city" id="editCity" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">@Localizer["Country"]</label>
                            <input type="text" name="country" id="editCountry" class="form-control" maxlength="2" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">@Localizer["Currency"]</label>
                            <select name="currency" id="editCurrency" class="form-select">
                                <option value="SAR">@Localizer["SAR – Saudi Riyal"]</option>
                                <option value="AED">@Localizer["AED – UAE Dirham"]</option>
                                <option value="KWD">@Localizer["KWD – Kuwaiti Dinar"]</option>
                                <option value="BHD">@Localizer["BHD – Bahraini Dinar"]</option>
                                <option value="QAR">@Localizer["QAR – Qatari Riyal"]</option>
                                <option value="OMR">@Localizer["OMR – Omani Rial"]</option>
                                <option value="USD">@Localizer["USD – US Dollar"]</option>
                                <option value="EUR">@Localizer["EUR – Euro"]</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">@Localizer["Default Language"]</label>
                            <select name="defaultLanguage" id="editDefaultLanguage" class="form-select">
                                <option value="ar">@Localizer["Arabic"]</option>
                                <option value="en">@Localizer["English"]</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Cancel"]</button>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg me-1"></i>@Localizer["Update Tenant"]
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function editTenant(id, name, nameAr, vatNumber, cr, phone, email, address, city, country, currency, defaultLanguage) {
    document.getElementById('editId').value = id;
    document.getElementById('editName').value = name;
    document.getElementById('editNameAr').value = nameAr;
    document.getElementById('editVatNumber').value = vatNumber;
    document.getElementById('editCR').value = cr;
    document.getElementById('editPhone').value = phone;
    document.getElementById('editEmail').value = email;
    document.getElementById('editAddress').value = address;
    document.getElementById('editCity').value = city;
    document.getElementById('editCountry').value = country;
    document.getElementById('editCurrency').value = currency;
    document.getElementById('editDefaultLanguage').value = defaultLanguage;
    new bootstrap.Modal(document.getElementById('editTenantModal')).show();
}
</script>
}
