@page
@model RestaurantPOS.Web.Pages.Account.LoginModel
@{
    Layout = null;
    ViewData["Title"] = Localizer["Sign In"];
}
<!DOCTYPE html>
<html lang="@(Model.IsArabic ? "ar" : "en")" dir="@(Model.IsArabic ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>RestaurantPOS - @Localizer["Sign In"]</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          crossorigin="anonymous" />
    @if (Model.IsArabic)
    {
        <link rel="stylesheet"
              href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css"
              crossorigin="anonymous" />
    }
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root { --pos-primary: #2d6a4f; --pos-secondary: #40916c; }
        body { background: linear-gradient(135deg, var(--pos-primary) 0%, var(--pos-secondary) 100%); min-height: 100vh; }
        .login-card { border: none; border-radius: 16px; box-shadow: 0 20px 60px rgba(0,0,0,.25); }
        .btn-primary { background: var(--pos-primary); border-color: var(--pos-primary); }
        .btn-primary:hover { background: var(--pos-secondary); border-color: var(--pos-secondary); }
        .logo-text { font-weight: 800; font-size: 2rem; letter-spacing: -1px; }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center">
    <div class="container" style="max-width: 440px;">
        <div class="text-center mb-4">
            <div class="logo-text text-white">
                <i class="bi bi-shop"></i> RestaurantPOS
            </div>
            <p class="text-white-50 mb-0">@Localizer["Your complete point of sale solution"]</p>
        </div>
        <div class="card login-card">
            <div class="card-body p-4">
                <h4 class="fw-bold mb-1">@Localizer["Sign In"]</h4>
                <p class="text-muted mb-4">@Localizer["Enter your credentials to continue"]</p>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>@Model.ErrorMessage
                    </div>
                }

                <form method="post" asp-page="/Account/Login">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Input.Email" class="form-control" autocomplete="email"
                                   placeholder="admin@restaurantpos.com" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input asp-for="Input.Password" type="password" class="form-control"
                                   autocomplete="current-password" />
                            <button class="btn btn-outline-secondary" type="button"
                                    onclick="togglePassword(this)">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input asp-for="Input.RememberMe" class="form-check-input" />
                            <label asp-for="Input.RememberMe" class="form-check-label">
                                @Localizer["Remember me"]
                            </label>
                        </div>
                        <a href="/Account/ForgotPassword" class="text-decoration-none small">
                            @Localizer["Forgot password?"]
                        </a>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                        <i class="bi bi-box-arrow-in-right me-2"></i>
                        @Localizer["Sign In"]
                    </button>
                </form>

                <hr class="my-4" />
                <div class="text-center">
                    <small class="text-muted">@Localizer["Language"]: </small>
                    <a href="?lang=ar" class="btn btn-sm btn-outline-secondary ms-1">@Localizer["Arabic"]</a>
                    <a href="?lang=en" class="btn btn-sm btn-outline-secondary ms-1">@Localizer["English"]</a>
                </div>
            </div>
        </div>
        <p class="text-center text-white-50 mt-3 small">
            &copy; @DateTime.Now.Year RestaurantPOS — @Localizer["Foodics-inspired POS"]
        </p>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function togglePassword(btn) {
            const input = btn.previousElementSibling;
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye';
            }
        }
        // Set language cookie
        const params = new URLSearchParams(location.search);
        if (params.has('lang')) {
            document.cookie = `.AspNetCore.Culture=c=${params.get('lang')}|uic=${params.get('lang')};path=/`;
            location.href = location.pathname;
        }
    </script>
</body>
</html>
