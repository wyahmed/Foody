@page "/Orders/{id:guid}"
@model RestaurantPOS.Web.Pages.Orders.DetailModel
@{
    ViewData["Title"] = $"Order {Model.Order?.OrderNumber}";
    ViewData["ActivePage"] = "Orders";
}

@if (Model.Order == null)
{
    <div class="alert alert-warning">@Localizer["Order not found."]</div>
    return;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <a asp-page="/Orders/Index" class="btn btn-outline-secondary btn-sm me-2">
            <i class="bi bi-arrow-left"></i> @Localizer["Back"]
        </a>
        <h4 class="d-inline-block mb-0">@Localizer["Order"] #@Model.Order.OrderNumber</h4>
    </div>
    <div>
        @{
            var sc = Model.Order.Status switch { "Completed" => "success", "Cancelled" => "danger", "Preparing" => "warning", "Ready" => "info", _ => "secondary" };
        }
        <span class="badge bg-@sc fs-6">@Localizer[Model.Order.Status]</span>
    </div>
</div>

<div class="row">
    <!-- Order Info -->
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header fw-semibold">@Localizer["Order Items"]</div>
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>@Localizer["Item"]</th>
                            <th class="text-center">@Localizer["Qty"]</th>
                            <th class="text-end">@Localizer["Unit Price"]</th>
                            <th class="text-end">@Localizer["Total"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Order.Items)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@item.ProductName</div>
                                    @if (!string.IsNullOrEmpty(item.Notes))
                                    {
                                        <small class="text-muted">@item.Notes</small>
                                    }
                                    @if (item.Modifiers.Any())
                                    {
                                        <div>@foreach (var m in item.Modifiers) { <span class="badge bg-light text-dark me-1">+@m</span> }</div>
                                    }
                                </td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end">@item.UnitPrice.ToString("N2")</td>
                                <td class="text-end fw-semibold">@item.TotalPrice.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="3" class="text-end">@Localizer["Subtotal"]</td>
                            <td class="text-end">@Model.Order.SubTotal.ToString("N2")</td>
                        </tr>
                        @if (Model.Order.DiscountAmount > 0)
                        {
                            <tr class="text-danger">
                                <td colspan="3" class="text-end">@Localizer["Discount"]</td>
                                <td class="text-end">-@Model.Order.DiscountAmount.ToString("N2")</td>
                            </tr>
                        }
                        @if (Model.Order.TaxAmount > 0)
                        {
                            <tr>
                                <td colspan="3" class="text-end">@Localizer["VAT (15%)"]</td>
                                <td class="text-end">@Model.Order.TaxAmount.ToString("N2")</td>
                            </tr>
                        }
                        <tr class="fw-bold">
                            <td colspan="3" class="text-end">@Localizer["Total"]</td>
                            <td class="text-end fs-5">@Model.Order.TotalAmount.ToString("N2") @Localizer["SAR"]</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <!-- Side Info -->
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header fw-semibold">@Localizer["Details"]</div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item d-flex justify-content-between">
                    <span>@Localizer["Type"]</span>
                    <strong>@Localizer[Model.Order.OrderType]</strong>
                </li>
                @if (!string.IsNullOrEmpty(Model.Order.TableName))
                {
                    <li class="list-group-item d-flex justify-content-between">
                        <span>@Localizer["Table"]</span>
                        <strong>@Model.Order.TableName</strong>
                    </li>
                }
                @if (!string.IsNullOrEmpty(Model.Order.CustomerName))
                {
                    <li class="list-group-item d-flex justify-content-between">
                        <span>@Localizer["Customer"]</span>
                        <strong>@Model.Order.CustomerName</strong>
                    </li>
                }
                <li class="list-group-item d-flex justify-content-between">
                    <span>@Localizer["Cashier"]</span>
                    <strong>@(Model.Order.CashierName ?? "-")</strong>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span>@Localizer["Date"]</span>
                    <strong>@Model.Order.CreatedDate.ToString("dd MMM yyyy HH:mm")</strong>
                </li>
                @if (!string.IsNullOrEmpty(Model.Order.Notes))
                {
                    <li class="list-group-item">
                        <div class="text-muted small">@Localizer["Notes"]</div>
                        <div>@Model.Order.Notes</div>
                    </li>
                }
            </ul>
        </div>

        @if (Model.Order.Payments.Any())
        {
            <div class="card">
                <div class="card-header fw-semibold">@Localizer["Payments"]</div>
                <ul class="list-group list-group-flush">
                    @foreach (var p in Model.Order.Payments)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span>@Localizer[p.Method]</span>
                            <strong>@p.Amount.ToString("N2")</strong>
                        </li>
                    }
                </ul>
            </div>
        }
    </div>
</div>
