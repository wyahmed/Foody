@page
@model RestaurantPOS.Web.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "Orders";
    ViewData["ActivePage"] = "Orders";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-receipt me-2"></i>@Localizer["Orders"]</h4>
    <a asp-page="/POS/Index" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>@Localizer["New Order"]
    </a>
</div>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <input type="text" name="search" value="@Model.Search"
                       class="form-control" placeholder="@Localizer["Search order number..."]" />
            </div>
            <div class="col-md-2">
                <select name="status" class="form-select">
                    <option value="">@Localizer["All Statuses"]</option>
                    <option value="Pending" selected="@(Model.Status == "Pending")">@Localizer["Pending"]</option>
                    <option value="Confirmed" selected="@(Model.Status == "Confirmed")">@Localizer["Confirmed"]</option>
                    <option value="Preparing" selected="@(Model.Status == "Preparing")">@Localizer["Preparing"]</option>
                    <option value="Ready" selected="@(Model.Status == "Ready")">@Localizer["Ready"]</option>
                    <option value="Delivered" selected="@(Model.Status == "Delivered")">@Localizer["Delivered"]</option>
                    <option value="Completed" selected="@(Model.Status == "Completed")">@Localizer["Completed"]</option>
                    <option value="Cancelled" selected="@(Model.Status == "Cancelled")">@Localizer["Cancelled"]</option>
                </select>
            </div>
            <div class="col-md-2">
                <select name="orderType" class="form-select">
                    <option value="">@Localizer["All Types"]</option>
                    <option value="DineIn" selected="@(Model.OrderType == "DineIn")">@Localizer["Dine In"]</option>
                    <option value="TakeAway" selected="@(Model.OrderType == "TakeAway")">@Localizer["Take Away"]</option>
                    <option value="Delivery" selected="@(Model.OrderType == "Delivery")">@Localizer["Delivery"]</option>
                    <option value="DriveThrough" selected="@(Model.OrderType == "DriveThrough")">@Localizer["Drive Through"]</option>
                </select>
            </div>
            <div class="col-md-2">
                <input type="date" name="dateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-2">
                <input type="date" name="dateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-outline-primary w-100">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Orders Table -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>@Localizer["Order #"]</th>
                        <th>@Localizer["Type"]</th>
                        <th>@Localizer["Table"]</th>
                        <th>@Localizer["Customer"]</th>
                        <th>@Localizer["Items"]</th>
                        <th>@Localizer["Total"]</th>
                        <th>@Localizer["Status"]</th>
                        <th>@Localizer["Time"]</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.Orders)
                    {
                        <tr>
                            <td><strong>@order.OrderNumber</strong></td>
                            <td>
                                @{
                                    var typeIcon = order.OrderType switch
                                    {
                                        "DineIn" => "bi-shop",
                                        "TakeAway" => "bi-bag",
                                        "Delivery" => "bi-bicycle",
                                        "DriveThrough" => "bi-car-front",
                                        _ => "bi-receipt"
                                    };
                                    var typeColor = order.OrderType switch
                                    {
                                        "DineIn" => "primary",
                                        "TakeAway" => "info",
                                        "Delivery" => "warning",
                                        "DriveThrough" => "secondary",
                                        _ => "dark"
                                    };
                                }
                                <span class="badge bg-@typeColor">
                                    <i class="bi @typeIcon me-1"></i>@Localizer[order.OrderType]
                                </span>
                            </td>
                            <td>@(order.TableName ?? "-")</td>
                            <td>@(order.CustomerName ?? Localizer["Walk-in"])</td>
                            <td>@order.ItemCount</td>
                            <td class="fw-bold">@order.Total.ToString("N2") @Localizer["SAR"]</td>
                            <td>
                                @{
                                    var statusColor = order.Status switch
                                    {
                                        "Pending" => "secondary",
                                        "Confirmed" => "primary",
                                        "Preparing" => "warning",
                                        "Ready" => "info",
                                        "Delivered" => "success",
                                        "Completed" => "success",
                                        "Cancelled" => "danger",
                                        _ => "secondary"
                                    };
                                }
                                <span class="badge bg-@statusColor">@Localizer[order.Status]</span>
                            </td>
                            <td class="text-muted small">@order.CreatedDate.ToString("hh:mm tt")</td>
                            <td>
                                <a asp-page="/Orders/Detail" asp-route-id="@order.Id" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (order.Status == "Pending" || order.Status == "Confirmed")
                                {
                                    <button class="btn btn-sm btn-outline-danger ms-1"
                                            onclick="confirmDelete('@order.Id', '@order.OrderNumber', '/Orders/Index?handler=Cancel')">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Orders.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                <i class="bi bi-inbox display-6 d-block mb-2"></i>
                                @Localizer["No orders found"]
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer d-flex justify-content-between align-items-center">
            <small class="text-muted">@Localizer["Showing {0}-{1} of {2}", Model.From, Model.To, Model.TotalCount]</small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link"
                               asp-page="/Orders/Index"
                               asp-route-page="@i"
                               asp-route-search="@Model.Search"
                               asp-route-status="@Model.Status">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
