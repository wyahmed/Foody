@page
@model RestaurantPOS.Web.Pages.Products.IndexModel
@{
    ViewData["Title"] = Localizer["Products"];
    ViewData["ActivePage"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-box-seam me-2"></i>@Localizer["Products"]</h4>
    <a asp-page="/Products/Edit" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>@Localizer["Add Product"]
    </a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2">
            <div class="col-md-4">
                <input type="text" name="search" value="@Model.Search"
                       class="form-control" placeholder="@Localizer["Search name, barcode, SKU..."]" />
            </div>
            <div class="col-md-3">
                <select name="categoryId" class="form-select">
                    <option value="">@Localizer["All Categories"]</option>
                    @foreach (var c in Model.Categories)
                    {
                        <option value="@c.Id" selected="@(Model.CategoryId == c.Id)">@c.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select name="isActive" class="form-select">
                    <option value="">@Localizer["All"]</option>
                    <option value="true" selected="@(Model.IsActive == true)">@Localizer["Active"]</option>
                    <option value="false" selected="@(Model.IsActive == false)">@Localizer["Inactive"]</option>
                </select>
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-outline-primary w-100"><i class="bi bi-search"></i></button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px"></th>
                        <th>@Localizer["Product"]</th>
                        <th>@Localizer["Category"]</th>
                        <th>@Localizer["SKU / Barcode"]</th>
                        <th>@Localizer["Price"]</th>
                        <th>@Localizer["Cost"]</th>
                        <th>@Localizer["Status"]</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Products)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(p.ImageUrl))
                                {
                                    <img src="@p.ImageUrl" class="rounded" width="40" height="40" style="object-fit:cover" />
                                }
                                else
                                {
                                    <div class="rounded bg-light d-flex align-items-center justify-content-center" style="width:40px;height:40px">
                                        <i class="bi bi-box text-muted"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="fw-semibold">@p.Name</div>
                                @if (!string.IsNullOrEmpty(p.NameAr))
                                {
                                    <small class="text-muted" dir="rtl">@p.NameAr</small>
                                }
                            </td>
                            <td><span class="badge bg-light text-dark">@p.CategoryName</span></td>
                            <td>
                                <code class="small">@(p.SKU ?? "-")</code>
                                @if (!string.IsNullOrEmpty(p.Barcode))
                                {
                                    <br /><code class="small text-muted">@p.Barcode</code>
                                }
                            </td>
                            <td class="fw-bold">@p.SellingPrice.ToString("N2")</td>
                            <td class="text-muted">@p.CostPrice.ToString("N2")</td>
                            <td>
                                <span class="badge bg-@(p.IsActive ? "success" : "secondary")">
                                    @(p.IsActive ? Localizer["Active"] : Localizer["Inactive"])
                                </span>
                            </td>
                            <td>
                                <a asp-page="/Products/Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button class="btn btn-sm btn-outline-danger ms-1"
                                        onclick="confirmDelete('@p.Id', '@p.Name', '?handler=Delete')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                    @if (!Model.Products.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">@Localizer["No products found"]</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer d-flex justify-content-between align-items-center">
            <small class="text-muted">@string.Format(Localizer["Showing {0}-{1} of {2}"], Model.From, Model.To, Model.TotalCount)</small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" asp-page="/Products/Index" asp-route-page="@i"
                               asp-route-search="@Model.Search" asp-route-categoryId="@Model.CategoryId">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
