@page
@model RestaurantPOS.Web.Pages.Reports.IndexModel
@{
    ViewData["Title"] = "Reports";
    ViewData["ActivePage"] = "Reports";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-bar-chart-line me-2"></i>@Localizer["Sales Reports"]</h4>
    <div class="d-flex gap-2">
        <form method="get" class="d-flex gap-2">
            <input type="date" name="dateFrom" value="@Model.DateFrom.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
            <input type="date" name="dateTo" value="@Model.DateTo.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
            <button type="submit" class="btn btn-sm btn-primary">@Localizer["Apply"]</button>
        </form>
        <form method="post" asp-page-handler="ExportExcel">
            <input type="hidden" name="dateFrom" value="@Model.DateFrom.ToString("yyyy-MM-dd")" />
            <input type="hidden" name="dateTo" value="@Model.DateTo.ToString("yyyy-MM-dd")" />
            <button type="submit" class="btn btn-sm btn-outline-success">
                <i class="bi bi-file-earmark-excel me-1"></i>@Localizer["Export"]
            </button>
        </form>
    </div>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted small mb-1">@Localizer["Total Sales"]</p>
                        <h4 class="mb-0 fw-bold">@Model.TotalSales.ToString("N2")</h4>
                        <small class="text-muted">@Localizer["SAR"]</small>
                    </div>
                    <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-currency-dollar fs-3 text-primary"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted small mb-1">@Localizer["Total Orders"]</p>
                        <h4 class="mb-0 fw-bold">@Model.TotalOrders</h4>
                        <small class="text-muted">@Localizer["orders"]</small>
                    </div>
                    <div class="bg-success bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-receipt fs-3 text-success"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted small mb-1">@Localizer["Average Order"]</p>
                        <h4 class="mb-0 fw-bold">@Model.AverageOrder.ToString("N2")</h4>
                        <small class="text-muted">@Localizer["SAR"]</small>
                    </div>
                    <div class="bg-info bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-graph-up fs-3 text-info"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted small mb-1">@Localizer["Total VAT"]</p>
                        <h4 class="mb-0 fw-bold">@Model.TotalVat.ToString("N2")</h4>
                        <small class="text-muted">@Localizer["SAR"]</small>
                    </div>
                    <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-percent fs-3 text-warning"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Top Products -->
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">@Localizer["Top Products"]</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>@Localizer["Product"]</th>
                            <th class="text-center">@Localizer["Qty"]</th>
                            <th class="text-end">@Localizer["Revenue"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int rank = 1; }
                        @foreach (var p in Model.TopProducts)
                        {
                            <tr>
                                <td><span class="badge bg-@(rank == 1 ? "warning" : rank == 2 ? "secondary" : rank == 3 ? "danger" : "light text-dark")">@rank</span></td>
                                <td>@p.ProductName</td>
                                <td class="text-center">@p.TotalQuantity</td>
                                <td class="text-end fw-bold">@p.TotalRevenue.ToString("N2")</td>
                            </tr>
                            rank++;
                        }
                        @if (!Model.TopProducts.Any())
                        {
                            <tr><td colspan="4" class="text-center text-muted py-3">@Localizer["No data"]</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Sales by Type -->
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">@Localizer["Sales by Order Type"]</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>@Localizer["Type"]</th>
                            <th class="text-center">@Localizer["Orders"]</th>
                            <th class="text-end">@Localizer["Total"]</th>
                            <th class="text-end">@Localizer["Share"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.SalesByType)
                        {
                            var share = Model.TotalSales > 0 ? (t.Total / Model.TotalSales * 100) : 0;
                            <tr>
                                <td>@Localizer[t.OrderType]</td>
                                <td class="text-center">@t.Count</td>
                                <td class="text-end">@t.Total.ToString("N2")</td>
                                <td class="text-end">
                                    <div class="d-flex align-items-center justify-content-end gap-2">
                                        <div class="progress flex-grow-1" style="height:6px;max-width:80px">
                                            <div class="progress-bar" style="width:@share%"></div>
                                        </div>
                                        <small>@share.ToString("N0")%</small>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Daily Sales -->
    <div class="col-12">
        <div class="card">
            <div class="card-header fw-semibold">@Localizer["Daily Sales Breakdown"]</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>@Localizer["Date"]</th>
                                <th class="text-center">@Localizer["Orders"]</th>
                                <th class="text-end">@Localizer["Sales"]</th>
                                <th class="text-end">@Localizer["Discount"]</th>
                                <th class="text-end">@Localizer["VAT"]</th>
                                <th class="text-end">@Localizer["Net"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in Model.DailySales)
                            {
                                <tr>
                                    <td>@d.Date.ToString("dd MMM yyyy (ddd)")</td>
                                    <td class="text-center">@d.OrderCount</td>
                                    <td class="text-end">@d.GrossSales.ToString("N2")</td>
                                    <td class="text-end text-danger">@d.Discount.ToString("N2")</td>
                                    <td class="text-end">@d.Vat.ToString("N2")</td>
                                    <td class="text-end fw-bold">@d.NetSales.ToString("N2")</td>
                                </tr>
                            }
                            @if (!Model.DailySales.Any())
                            {
                                <tr><td colspan="6" class="text-center text-muted py-3">@Localizer["No data"]</td></tr>
                            }
                        </tbody>
                        <tfoot class="table-light fw-bold">
                            <tr>
                                <td>@Localizer["Total"]</td>
                                <td class="text-center">@Model.TotalOrders</td>
                                <td class="text-end">@Model.GrossSales.ToString("N2")</td>
                                <td class="text-end text-danger">@Model.TotalDiscount.ToString("N2")</td>
                                <td class="text-end">@Model.TotalVat.ToString("N2")</td>
                                <td class="text-end">@Model.TotalSales.ToString("N2")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
